{% extends 'base.html.twig' %}

{% block title %}{{ 'stats.dashboard.heading'|trans }}{% endblock %}

{% block body %}

<div class="page-header">
    <div class="page-header-text">
        <h1 class="page-title">{{ 'stats.dashboard.heading'|trans }}</h1>
    </div>
    <div class="page-header-actions">
        {# Year filter pills #}
        <div class="year-filter-pills" style="margin-bottom: 0;">
            <a href="{{ path('app_stats_dashboard') }}"
               class="year-pill{% if year is null %} active{% endif %}">
                {{ 'stats.filter.all_time'|trans }}
            </a>
            {% for y in summary.availableYears %}
                <a href="{{ path('app_stats_dashboard', {year: y}) }}"
                   class="year-pill{% if y == year %} active{% endif %}">
                    {{ y }}
                </a>
            {% endfor %}
        </div>
    </div>
</div>

{% if summary.entryCount == 0 and year is null %}
    <div class="empty-state">
        <p class="empty-state-text">{{ 'stats.dashboard.empty'|trans }}</p>
    </div>
{% else %}

{# ── Summary cards ──────────────────────────────────────────────────────── #}
<div class="row g-3 mb-6">

    <div class="col-6 col-md-4 col-xl">
        <div class="stat-card">
            <div class="stat-card-value">{{ summary.uniqueWorkCount }}</div>
            <div class="stat-card-label">{{ 'stats.card.unique_works'|trans }}</div>
        </div>
    </div>

    <div class="col-6 col-md-4 col-xl">
        <div class="stat-card">
            <div class="stat-card-value">{{ summary.wordCountStats.totalWords|number_format }}</div>
            <div class="stat-card-label">
                {% if year %}
                    {{ 'stats.card.words_in'|trans({'%year%': year}) }}
                {% else %}
                    {{ 'stats.card.total_words'|trans }}
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-6 col-md-4 col-xl">
        <div class="stat-card">
            <div class="stat-card-value">
                {% if summary.wordCountStats.averageWords is not null %}
                    {{ summary.wordCountStats.averageWords|number_format }}
                {% else %}
                    —
                {% endif %}
            </div>
            <div class="stat-card-label">{{ 'stats.card.avg_words'|trans }}</div>
            {% if summary.wordCountStats.entryCount > 0 and summary.wordCountStats.entryCount < summary.finishedCount %}
                <div class="stat-card-sub">
                    {{ 'stats.card.avg_words_subtitle'|trans({'%count%': summary.wordCountStats.entryCount}) }}
                </div>
            {% endif %}
        </div>
    </div>

    <div class="col-6 col-md-4 col-xl">
        <div class="stat-card">
            <div class="stat-card-value">{{ summary.finishRate }}%</div>
            <div class="stat-card-label">{{ 'stats.card.finish_rate'|trans }}</div>
        </div>
    </div>

    <div class="col-6 col-md-4 col-xl">
        <div class="stat-card">
            <div class="stat-card-value">
                {% if summary.averageRating is not null %}
                    <i class="bi bi-star-fill star-icon" aria-hidden="true"></i> {{ summary.averageRating }}
                {% else %}
                    —
                {% endif %}
            </div>
            <div class="stat-card-label">{{ 'stats.card.avg_rating'|trans }}</div>
        </div>
    </div>

    <div class="col-6 col-md-4 col-xl">
        <div class="stat-card">
            <div class="stat-card-value">
                {% if summary.averageSpice is not null %}
                    <i class="bi bi-fire spice-icon" aria-hidden="true"></i> {{ summary.averageSpice }}
                {% else %}
                    —
                {% endif %}
            </div>
            <div class="stat-card-label">{{ 'stats.card.avg_spice'|trans }}</div>
        </div>
    </div>

    <div class="col-6 col-md-4 col-xl">
        <div class="stat-card">
            <div class="stat-card-value">
                {% if readingPace.averageDays is not null %}
                    {{ readingPace.averageDays }}d
                {% else %}
                    —
                {% endif %}
            </div>
            <div class="stat-card-label">
                {{ 'stats.card.reading_pace'|trans }}
                {% if readingPace.entryCount > 0 %}
                    <i class="bi bi-info-circle ms-1"
                       data-bs-toggle="tooltip"
                       data-bs-trigger="hover focus click"
                       data-bs-title="{{ 'stats.card.reading_pace_subtitle'|trans({'%count%': readingPace.entryCount}) }}"
                       style="cursor:pointer"></i>
                {% endif %}
            </div>
        </div>
    </div>

</div>

{# ── Reading goals progress (current year, above tabs) ────────────────────── #}
{% if goalsWithProgress is not empty %}
<div class="chart-card mb-4">
    <div class="chart-card-header">
        <span class="chart-card-title">
            {{ 'goal.dashboard.heading'|trans({'%year%': currentYear}) }}
        </span>
        <a href="{{ path('app_goals') }}" class="btn btn-sm btn-ghost">
            {{ 'goal.dashboard.manage'|trans }}
        </a>
    </div>
    <div class="chart-card-body">
        <div class="row g-3">
            {% for item in goalsWithProgress %}
            <div class="col-12 col-md-6">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span style="font-size: var(--text-sm);">
                        {{ ('goal.type.' ~ item.goal.goalType.value)|trans }}
                    </span>
                    <span style="font-size: var(--text-sm); color: var(--color-text-muted);">
                        {{ item.currentValue|number_format }} / {{ item.goal.targetValue|number_format }}
                        {% if item.progressPct >= 100 %}
                            <i class="bi bi-check-circle-fill text-success ms-1" aria-hidden="true"></i>
                        {% endif %}
                    </span>
                </div>
                <div class="progress" style="height: 8px;" role="progressbar"
                     aria-valuenow="{{ item.progressPct|round }}"
                     aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar{% if item.progressPct >= 100 %} bg-success{% endif %}"
                         style="width: {{ item.progressPct }}%"></div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% else %}
<div class="mb-4 text-end" style="font-size: var(--text-sm);">
    <a href="{{ path('app_goals') }}" class="text-muted">
        <i class="bi bi-plus-circle me-1" aria-hidden="true"></i>{{ 'goal.dashboard.set_goal'|trans({'%year%': currentYear}) }}
    </a>
</div>
{% endif %}

{# ── Tabs ─────────────────────────────────────────────────────────────────── #}
<div class="analytics-tabs" role="tablist">
    <button class="analytics-tab active" id="tab-overview-btn"
            data-bs-toggle="tab" data-bs-target="#tab-overview"
            type="button" role="tab"
            aria-selected="true" aria-controls="tab-overview">
        {{ 'stats.dashboard.tab_overview'|trans }}
    </button>
    <button class="analytics-tab" id="tab-breakdown-btn"
            data-bs-toggle="tab" data-bs-target="#tab-breakdown"
            type="button" role="tab"
            aria-selected="false" aria-controls="tab-breakdown">
        {{ 'stats.dashboard.tab_breakdown'|trans }}
    </button>
    <button class="analytics-tab" id="tab-achievements-btn"
            data-bs-toggle="tab" data-bs-target="#tab-achievements"
            type="button" role="tab"
            aria-selected="false" aria-controls="tab-achievements">
        {{ 'stats.dashboard.tab_achievements'|trans }}
    </button>
</div>

<div class="tab-content">

    {# ── Overview tab ─────────────────────────────────────────────────────── #}
    <div class="tab-pane fade show active" id="tab-overview" role="tabpanel">

        {# Trend chart #}
        <div class="chart-card mb-4">
            <div class="chart-card-header">
                <span class="chart-card-title">
                    {{ year ? 'stats.chart.monthly_trend'|trans : 'stats.chart.yearly_trend'|trans }}
                </span>
            </div>
            <div class="chart-card-body">
                {% if trendData is empty %}
                    <p class="empty-state-text">{{ 'stats.card.no_data'|trans }}</p>
                {% else %}
                    <canvas id="trend-chart"
                        data-controller="chart"
                        data-chart-type-value="line"
                        data-chart-labels-value="{{ trendData|keys|map(k => year ? ('stats.month.' ~ k)|trans : k)|json_encode }}"
                        data-chart-datasets-value="{{ [
                            {
                                'label': 'stats.chart.words'|trans,
                                'data': wordTrendData|values,
                                'backgroundColor': 'rgba(194,155,80,0.08)',
                                'borderColor': 'rgba(194,155,80,1)',
                                'pointBackgroundColor': 'rgba(194,155,80,1)',
                                'fill': true,
                                'tension': 0.3,
                                'yAxisID': 'y'
                            },
                            {
                                'label': 'stats.chart.entries'|trans,
                                'data': trendData|values,
                                'backgroundColor': 'rgba(59,107,82,0.12)',
                                'borderColor': 'rgba(59,107,82,1)',
                                'pointBackgroundColor': 'rgba(59,107,82,1)',
                                'fill': true,
                                'tension': 0.3,
                                'yAxisID': 'y1'
                            }
                        ]|json_encode }}"
                        data-chart-options-value="{{ {
                            'plugins': {'legend': {'display': true, 'position': 'bottom', 'labels': {'boxWidth': 12, 'padding': 16}}},
                            'scales': {
                                'y':  {'type': 'linear', 'position': 'left',  'ticks': {'precision': 0}, 'grid': {'color': 'rgba(221,232,228,0.6)'}},
                                'y1': {'type': 'linear', 'position': 'right', 'ticks': {'precision': 0}, 'grid': {'drawOnChartArea': false}},
                                'x':  {'grid': {'display': false}}
                            },
                            'aspectRatio': 4
                        }|json_encode }}"
                        data-chart-urls-value="{{ chartUrls.trend|json_encode }}"
                    ></canvas>
                {% endif %}
            </div>
        </div>

        {# Top Reads spotlight #}
        <div class="chart-card mb-4">
            <div class="chart-card-header">
                <span class="chart-card-title">{{ 'stats.card.top_reads'|trans }}</span>
            </div>
            <div class="chart-card-body">
                <div class="row g-4">
                    {% for key, spotlight in topMetadata %}
                        <div class="col-md-6">
                            <div class="stat-card-label mb-1">{{ ('stats.card.top_' ~ key)|trans }}</div>
                            <div class="d-flex align-items-baseline gap-2">
                                {% if spotlight %}
                                    <span style="font-weight: var(--weight-semibold); color: var(--color-primary);">{{ spotlight.name }}</span>
                                    <span style="font-size: var(--text-xs); color: var(--color-text-muted);">· {{ spotlight.count }} {{ spotlight.count == 1 ? 'read' : 'reads' }}</span>
                                    {% if spotlight.ties is not empty %}
                                        <button type="button"
                                                class="btn btn-ghost"
                                                style="font-size: var(--text-xs); padding: 0 var(--space-1); min-height: 0; color: var(--color-primary-light);"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modal-top-{{ key }}">
                                            +{{ spotlight.ties|length }}
                                        </button>
                                    {% endif %}
                                {% else %}
                                    <span style="color: var(--color-text-faint);">—</span>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# Rankings quick links #}
        <div class="chart-card">
            <div class="chart-card-header">
                <span class="chart-card-title">{{ 'stats.rankings.available'|trans }}</span>
            </div>
            <div class="chart-card-body">
                <div class="d-flex flex-wrap gap-2">
                    <a href="{{ path('app_stats_rankings_status', {'year': year}) }}" class="chip chip-tag">{{ 'stats.rankings.type_status'|trans }}</a>
                    <a href="{{ path('app_stats_rankings_language', {'year': year}) }}" class="chip chip-tag">{{ 'stats.rankings.type_language'|trans }}</a>
                    <a href="{{ path('app_stats_rankings_main_pairing', {'year': year}) }}" class="chip chip-tag">{{ 'stats.rankings.type_main_pairing'|trans }}</a>
                    <a href="{{ path('app_stats_rankings_author', {'year': year}) }}" class="chip chip-tag">{{ 'stats.rankings.type_author'|trans }}</a>
                    <a href="{{ path('app_stats_rankings_series', {'year': year}) }}" class="chip chip-tag">{{ 'stats.rankings.type_series'|trans }}</a>
                    {% for typeName in rankingTypes %}
                        {% if typeName != 'Author' %}
                            <a href="{{ path('app_stats_rankings', {'type': typeName, 'year': year}) }}" class="chip chip-tag">{{ typeName }}</a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>

    </div>{# end tab-overview #}

    {# ── Breakdown tab ────────────────────────────────────────────────────── #}
    <div class="tab-pane fade" id="tab-breakdown" role="tabpanel">

        {# Donut row 1: Category + Rating #}
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="chart-card h-100">
                    <div class="chart-card-header">
                        <span class="chart-card-title">{{ 'stats.chart.by_category'|trans }}</span>
                    </div>
                    <div class="chart-card-body">
                        {% if metadataDistributions['Category'] is empty %}
                            <p class="empty-state-text">{{ 'stats.card.no_data'|trans }}</p>
                        {% else %}
                            <div class="donut-layout">
                                <div class="donut-canvas">
                                    <canvas
                                        data-controller="chart"
                                        data-chart-type-value="doughnut"
                                        data-chart-labels-value="{{ metadataDistributions['Category']|keys|json_encode }}"
                                        data-chart-datasets-value="{{ [{'data': metadataDistributions['Category']|values}]|json_encode }}"
                                        data-chart-options-value="{{ {'plugins': {'legend': {'display': false}}}|json_encode }}"
                                        data-chart-urls-value="{{ chartUrls.metaCategory|json_encode }}"
                                    ></canvas>
                                </div>
                                <div class="donut-legend">
                                    {% for name, count in metadataDistributions['Category'] %}
                                        <div class="donut-legend-row">
                                            <span class="donut-legend-name">{{ name }}</span>
                                            <span class="donut-legend-count">{{ count }}</span>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="chart-card h-100">
                    <div class="chart-card-header">
                        <span class="chart-card-title">{{ 'stats.chart.by_rating'|trans }}</span>
                    </div>
                    <div class="chart-card-body">
                        {% if metadataDistributions['Rating'] is empty %}
                            <p class="empty-state-text">{{ 'stats.card.no_data'|trans }}</p>
                        {% else %}
                            <div class="donut-layout">
                                <div class="donut-canvas">
                                    <canvas
                                        data-controller="chart"
                                        data-chart-type-value="doughnut"
                                        data-chart-labels-value="{{ metadataDistributions['Rating']|keys|json_encode }}"
                                        data-chart-datasets-value="{{ [{'data': metadataDistributions['Rating']|values}]|json_encode }}"
                                        data-chart-options-value="{{ {'plugins': {'legend': {'display': false}}}|json_encode }}"
                                        data-chart-urls-value="{{ chartUrls.metaRating|json_encode }}"
                                    ></canvas>
                                </div>
                                <div class="donut-legend">
                                    {% for name, count in metadataDistributions['Rating'] %}
                                        <div class="donut-legend-row">
                                            <span class="donut-legend-name">{{ name }}</span>
                                            <span class="donut-legend-count">{{ count }}</span>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {# Donut row 2: Warning + Status #}
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="chart-card h-100">
                    <div class="chart-card-header">
                        <span class="chart-card-title">{{ 'stats.chart.by_warning'|trans }}</span>
                    </div>
                    <div class="chart-card-body">
                        {% if metadataDistributions['Warning'] is empty %}
                            <p class="empty-state-text">{{ 'stats.card.no_data'|trans }}</p>
                        {% else %}
                            <div class="donut-layout">
                                <div class="donut-canvas">
                                    <canvas
                                        data-controller="chart"
                                        data-chart-type-value="doughnut"
                                        data-chart-labels-value="{{ metadataDistributions['Warning']|keys|json_encode }}"
                                        data-chart-datasets-value="{{ [{'data': metadataDistributions['Warning']|values}]|json_encode }}"
                                        data-chart-options-value="{{ {'plugins': {'legend': {'display': false}}}|json_encode }}"
                                        data-chart-urls-value="{{ chartUrls.metaWarning|json_encode }}"
                                    ></canvas>
                                </div>
                                <div class="donut-legend">
                                    {% for name, count in metadataDistributions['Warning'] %}
                                        <div class="donut-legend-row">
                                            <span class="donut-legend-name">{{ name }}</span>
                                            <span class="donut-legend-count">{{ count }}</span>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="chart-card h-100">
                    <div class="chart-card-header">
                        <span class="chart-card-title">{{ 'stats.card.by_status'|trans }}</span>
                    </div>
                    <div class="chart-card-body">
                        {% if summary.byStatus is empty %}
                            <p class="empty-state-text">{{ 'stats.card.no_data'|trans }}</p>
                        {% else %}
                            <div class="donut-layout">
                                <div class="donut-canvas">
                                    <canvas
                                        data-controller="chart"
                                        data-chart-type-value="doughnut"
                                        data-chart-labels-value="{{ summary.byStatus|keys|json_encode }}"
                                        data-chart-datasets-value="{{ [{'data': summary.byStatus|values}]|json_encode }}"
                                        data-chart-options-value="{{ {'plugins': {'legend': {'display': false}}}|json_encode }}"
                                        data-chart-urls-value="{{ chartUrls.status|json_encode }}"
                                    ></canvas>
                                </div>
                                <div class="donut-legend">
                                    {% for status, count in summary.byStatus %}
                                        <div class="donut-legend-row">
                                            <span class="donut-legend-name">{{ status }}</span>
                                            <span class="donut-legend-count">{{ count }}</span>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {# Work length distribution #}
        <div class="chart-card mb-4">
            <div class="chart-card-header">
                <span class="chart-card-title">{{ 'stats.chart.word_length_distribution'|trans }}</span>
            </div>
            <div class="chart-card-body">
                {% set wcdTotal = wordCountDistribution|reduce((carry, v) => carry + v, 0) %}
                {% if wcdTotal == 0 %}
                    <p class="empty-state-text">{{ 'stats.card.no_data'|trans }}</p>
                {% else %}
                    <canvas
                        data-controller="chart"
                        data-chart-type-value="bar"
                        data-chart-labels-value="{{ ['< 1K', '1K–10K', '10K–50K', '50K–100K', '> 100K']|json_encode }}"
                        data-chart-datasets-value="{{ [{'label': 'stats.chart.entries'|trans, 'data': wordCountDistribution|values, 'backgroundColor': 'rgba(59,107,82,0.70)', 'borderRadius': 4}]|json_encode }}"
                        data-chart-options-value="{{ {'plugins': {'legend': {'display': false}}, 'scales': {'y': {'ticks': {'precision': 0}, 'grid': {'color': 'rgba(221,232,228,0.6)'}}, 'x': {'grid': {'display': false}}}, 'aspectRatio': 4}|json_encode }}"
                        data-chart-urls-value="{{ chartUrls.wordCount|json_encode }}"
                    ></canvas>
                {% endif %}
            </div>
        </div>

        {# Review + spice distributions #}
        <div class="row g-4">
            <div class="col-md-6">
                <div class="chart-card h-100">
                    <div class="chart-card-header">
                        <span class="chart-card-title">{{ 'stats.chart.rating_distribution'|trans }}</span>
                    </div>
                    <div class="chart-card-body">
                        <canvas
                            data-controller="chart"
                            data-chart-type-value="bar"
                            data-chart-labels-value="{{ ratingDistributions.review|keys|map(k => '⭐' ~ k)|json_encode }}"
                            data-chart-datasets-value="{{ [{'label': 'stats.chart.entries'|trans, 'data': ratingDistributions.review|values, 'backgroundColor': 'rgba(196,164,113,0.80)', 'borderRadius': 4}]|json_encode }}"
                            data-chart-options-value="{{ {'plugins': {'legend': {'display': false}}, 'scales': {'y': {'ticks': {'precision': 0}, 'grid': {'color': 'rgba(221,232,228,0.6)'}}, 'x': {'grid': {'display': false}}}}|json_encode }}"
                            data-chart-urls-value="{{ chartUrls.rating|json_encode }}"
                        ></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="chart-card h-100">
                    <div class="chart-card-header">
                        <span class="chart-card-title">{{ 'stats.chart.spice_distribution'|trans }}</span>
                    </div>
                    <div class="chart-card-body">
                        <canvas
                            data-controller="chart"
                            data-chart-type-value="bar"
                            data-chart-labels-value="{{ ratingDistributions.spice|keys|map(k => k == 0 ? '🚫' : '🔥' ~ k)|json_encode }}"
                            data-chart-datasets-value="{{ [{'label': 'stats.chart.entries'|trans, 'data': ratingDistributions.spice|values, 'backgroundColor': 'rgba(180,70,70,0.70)', 'borderRadius': 4}]|json_encode }}"
                            data-chart-options-value="{{ {'plugins': {'legend': {'display': false}}, 'scales': {'y': {'ticks': {'precision': 0}, 'grid': {'color': 'rgba(221,232,228,0.6)'}}, 'x': {'grid': {'display': false}}}}|json_encode }}"
                            data-chart-urls-value="{{ chartUrls.spice|json_encode }}"
                        ></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>{# end tab-breakdown #}

    {# ── Achievements tab ──────────────────────────────────────────────────── #}
    <div class="tab-pane fade" id="tab-achievements" role="tabpanel">

        {# Recently unlocked #}
        {% if recentAchievements is not empty %}
        <div class="chart-card mb-4">
            <div class="chart-card-header">
                <span class="chart-card-title">{{ 'achievement.dashboard.recent'|trans }}</span>
                <a href="{{ path('app_achievements') }}" class="btn btn-sm btn-ghost">
                    {{ 'achievement.dashboard.view_all'|trans }}
                </a>
            </div>
            <div class="chart-card-body">
                <div class="d-flex flex-column gap-3">
                    {% for ua in recentAchievements %}
                        {% set def = achievementProgress[ua.achievementKey].definition %}
                        <div class="d-flex align-items-center gap-3">
                            <div class="achievement-icon-sm">
                                <i class="bi {{ def.icon }}" aria-hidden="true"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div style="font-weight: var(--weight-semibold); font-size: var(--text-sm);">
                                    {{ def.nameKey|trans }}
                                </div>
                                <div style="font-size: var(--text-xs); color: var(--color-text-muted);">
                                    {{ ua.unlockedAt|date('M j, Y') }}
                                </div>
                            </div>
                            <i class="bi bi-check-circle-fill text-success" aria-hidden="true"></i>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% else %}
        <div class="chart-card mb-4">
            <div class="chart-card-body">
                <p class="empty-state-text">{{ 'achievement.dashboard.none_yet'|trans }}</p>
            </div>
        </div>
        {% endif %}

        {# Next to unlock #}
        {% if nextAchievements is not empty %}
        <div class="chart-card">
            <div class="chart-card-header">
                <span class="chart-card-title">{{ 'achievement.dashboard.next'|trans }}</span>
            </div>
            <div class="chart-card-body">
                <div class="d-flex flex-column gap-3">
                    {% for item in nextAchievements %}
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <i class="bi {{ item.definition.icon }}" style="font-size: var(--text-base); color: var(--color-text-muted);" aria-hidden="true"></i>
                                <span style="font-size: var(--text-sm); font-weight: var(--weight-semibold);">
                                    {{ item.definition.nameKey|trans }}
                                </span>
                                <span class="ms-auto" style="font-size: var(--text-xs); color: var(--color-text-muted);">
                                    {{ item.current|number_format }} / {{ item.target|number_format }}
                                </span>
                            </div>
                            <div class="progress" style="height: 5px;" role="progressbar"
                                 aria-valuenow="{{ item.progressPct|round }}"
                                 aria-valuemin="0" aria-valuemax="100">
                                <div class="progress-bar" style="width: {{ item.progressPct }}%"></div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
                <div class="mt-3 text-end">
                    <a href="{{ path('app_achievements') }}" style="font-size: var(--text-sm);">
                        {{ 'achievement.dashboard.view_all'|trans }}
                    </a>
                </div>
            </div>
        </div>
        {% endif %}

    </div>{# end tab-achievements #}

</div>{# end tab-content #}

{# Tie modals #}
{% for key, spotlight in topMetadata %}
    {% if spotlight and spotlight.ties is not empty %}
        <div class="modal fade" id="modal-top-{{ key }}" tabindex="-1"
             aria-labelledby="modal-top-{{ key }}-label" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="modal-top-{{ key }}-label">
                            {{ 'stats.modal.tied_at_first'|trans({'%type%': ('stats.card.top_' ~ key)|trans}) }}
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                aria-label="{{ 'action.close'|trans }}"></button>
                    </div>
                    <div class="modal-body d-flex flex-column gap-2">
                        {% for entry in [{'name': spotlight.name, 'count': spotlight.count}]|merge(spotlight.ties) %}
                            <div>
                                {{ entry.name }}
                                <span style="font-size: var(--text-xs); color: var(--color-text-muted);" class="ms-1">· {{ entry.count }} {{ entry.count == 1 ? 'read' : 'reads' }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endfor %}

{% endif %}
{% endblock %}
