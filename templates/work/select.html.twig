{% extends 'base.html.twig' %}

{% block title %}{{ 'work.select_heading'|trans }}{% endblock %}

{% block body %}

<div class="page-header">
    <div class="page-header-text">
        <h1 class="page-title">{{ 'work.select_heading'|trans }}</h1>
        <p class="page-subtitle">{{ 'work.select_prompt'|trans }}</p>
    </div>
</div>

{# Import form — most common workflow #}
<div class="work-select-section mb-4">
    <p class="work-select-section-label">{{ 'work.import_separator'|trans }}</p>
    <form method="post" action="{{ path('app_work_select') }}"
          data-controller="loading-form">
        <input type="hidden" name="_import_token" value="{{ csrf_token('import_url') }}">
        <label for="import_url" class="form-label">{{ 'import.url_field'|trans }}</label>
        <div class="input-group">
            <input type="url" id="import_url" name="import_url"
                   class="form-control"
                   placeholder="{{ 'import.url_placeholder'|trans }}"
                   autocomplete="off"
                   data-loading-form-target="field">
            <button type="submit" class="btn btn-primary"
                    name="import_mode"
                    value="url"
                    data-loading-form-target="submit"
                    data-loading-text="{{ 'import.submit_loading'|trans }}">
                <i class="bi bi-cloud-download" aria-hidden="true"></i>
                {{ 'import.download_submit'|trans }}
            </button>
            <button type="submit" class="btn btn-secondary"
                    name="import_mode"
                    value="paste"
                    data-loading-form-target="submit"
                    data-loading-text="{{ 'import.paste_continue_loading'|trans }}">
                <i class="bi bi-clipboard-plus" aria-hidden="true"></i>
                {{ 'import.paste_continue'|trans }}
            </button>
        </div>
        <div class="form-text">{{ 'import.url_help'|trans }}</div>
    </form>
</div>

{# Separator #}
<div class="separator-or my-4">
    <span>{{ 'work.search_separator'|trans }}</span>
</div>

{# Search form with autocomplete #}
<form method="get" action="{{ path('app_work_select') }}" class="mb-4">
    <div class="position-relative"
         data-controller="autocomplete"
         data-autocomplete-url-value="{{ path('api_work_search') }}"
         data-autocomplete-submit-on-select-value="true"
         data-autocomplete-allow-new-value="true"
         data-autocomplete-create-url-value="{{ path('app_work_new') }}"
         data-autocomplete-min-chars-value="2">
        <div class="input-group">
            <input type="search" name="q" value="{{ query }}"
                   class="form-control"
                   placeholder="{{ 'work.select_search_placeholder'|trans }}"
                   aria-label="{{ 'work.select_search'|trans }}"
                   autocomplete="off"
                   data-autocomplete-target="input">
            <button type="submit" class="btn btn-secondary">
                <i class="bi bi-search" aria-hidden="true"></i>
                {{ 'work.select_search'|trans }}
            </button>
        </div>
        <ul class="dropdown-menu w-100" data-autocomplete-target="results" style="display:none; max-height:200px; overflow-y:auto;"></ul>
    </div>
</form>

{# Search results #}
{% if query is not empty %}
    {% if works is empty %}
        <div class="empty-state py-4">
            <p class="empty-state-text">{{ 'work.select_no_results'|trans }}</p>
            <a href="{{ path('app_work_new') }}" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                {{ 'work.create_new'|trans }}
            </a>
        </div>
    {% else %}
        <div class="work-search-results mb-4">
            {% for work in works %}
                <div class="work-search-result">
                    {# Mini cover thumbnail #}
                    <div class="cover cover-thumbnail {{ cover_font_class(work.type.value) }}"
                         style="{{ cover_gradient(work.id) }}"
                         aria-hidden="true">
                        <span class="cover-title">{{ work.title }}</span>
                    </div>

                    {# Work info #}
                    <div class="work-search-result-info">
                        <button type="button"
                                class="work-search-result-title work-preview-trigger"
                                data-bs-toggle="offcanvas"
                                data-bs-target="#workPreviewOffcanvas"
                                data-work-title="{{ work.title|e('html_attr') }}"
                                data-preview-url="{{ path('app_work_preview', {id: work.id}) }}"
                                data-entry-url="{{ path('app_reading_entry_new', {workId: work.id}) }}"
                                data-detail-url="{{ path('app_work_show', {id: work.id}) }}">
                            {{ work.title }}
                        </button>
                        <div class="work-search-result-meta">
                            {% if work.authors is not empty %}
                                <span>{{ work.authors|map(a => a.name)|join(', ') }}</span>
                            {% endif %}
                            {% if work.series %}
                                <span class="text-separator">·</span>
                                <span>{{ work.series.name }}</span>
                            {% endif %}
                        </div>
                    </div>

                    {# Actions #}
                    <div class="work-search-result-actions">
                        <span class="chip chip-tag">{{ work.type.value }}</span>
                        <a href="{{ path('app_reading_entry_new', {workId: work.id}) }}"
                           class="btn btn-primary btn-sm">
                            <i class="bi bi-plus-lg" aria-hidden="true"></i>
                            {{ 'reading.entry.add'|trans }}
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endif %}

{# Create manually fallback #}
<div class="mt-2">
    <a href="{{ path('app_work_new') }}" class="btn btn-ghost">
        <i class="bi bi-pencil" aria-hidden="true"></i>
        {{ 'work.create_new'|trans }}
    </a>
</div>

{# Work preview offcanvas — populated via fetch() when a result title is clicked #}
<div class="offcanvas offcanvas-end" tabindex="-1" id="workPreviewOffcanvas"
     aria-labelledby="workPreviewOffcanvasTitle"
     style="width: min(500px, 90vw)">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title text-truncate" id="workPreviewOffcanvasTitle"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="{{ 'action.close'|trans }}"></button>
    </div>
    <div class="offcanvas-body" id="workPreviewOffcanvasBody"></div>
    <div class="border-top p-3 d-flex gap-2" id="workPreviewOffcanvasFooter"></div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var offcanvasEl = document.getElementById('workPreviewOffcanvas');
    if (!offcanvasEl) { return; }

    offcanvasEl.addEventListener('show.bs.offcanvas', function (event) {
        var trigger = event.relatedTarget;
        if (!trigger) { return; }

        var title      = trigger.getAttribute('data-work-title') || '';
        var previewUrl = trigger.getAttribute('data-preview-url') || '';
        var entryUrl   = trigger.getAttribute('data-entry-url') || '';
        var detailUrl  = trigger.getAttribute('data-detail-url') || '';

        document.getElementById('workPreviewOffcanvasTitle').textContent = title;

        document.getElementById('workPreviewOffcanvasBody').innerHTML =
            '<div class="d-flex justify-content-center py-5">' +
                '<div class="spinner-border text-secondary" role="status">' +
                    '<span class="visually-hidden">Loading\u2026</span>' +
                '</div>' +
            '</div>';

        document.getElementById('workPreviewOffcanvasFooter').innerHTML =
            '<a href="' + entryUrl + '" class="btn btn-primary">' +
                '<i class="bi bi-plus-lg me-1" aria-hidden="true"></i>{{ 'reading.entry.add'|trans }}' +
            '</a>' +
            '<a href="' + detailUrl + '" class="btn btn-ghost">' +
                '{{ 'work.preview.view_details'|trans }}' +
            '</a>';

        if (!previewUrl) { return; }
        fetch(previewUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function (r) {
                return r.ok ? r.text() : Promise.reject(r.status);
            })
            .then(function (html) {
                document.getElementById('workPreviewOffcanvasBody').innerHTML = html;
            })
            .catch(function () {
                document.getElementById('workPreviewOffcanvasBody').innerHTML =
                    '<p class="text-danger">{{ 'work.preview.load_error'|trans }}</p>';
            });
    });
});
</script>
{% endblock %}
