{#
 # Reading entry table row — included by list.html.twig for both the main list
 # and the pinned section.
 #
 # Variables (passed via `with ... only`):
 #   entry          ReadingEntry  — the entry to render
 #   showCheckbox   bool          — whether to render the checkbox column (false for pinned section)
 #   usePinForm     bool          — when true, pin buttons use the shared #pin-form + JS instead of
 #                                  an inline <form>. Required when this partial is rendered inside
 #                                  #bulk-form to avoid invalid nested form elements.
 #}
{% set showCheckbox = showCheckbox is defined ? showCheckbox : true %}
{% set usePinForm = usePinForm is defined ? usePinForm : false %}
{% set statusSlug = entry.status.name|lower|replace({' ': '-'}) %}
{% set chipClass = 'chip chip--' ~ statusSlug %}

{% set fandomName = null %}
{% if not entry.work.deleted %}
    {% for m in entry.work.metadata %}
        {% if fandomName is null and m.metadataType.name == 'Fandom' %}
            {% set fandomName = m.name %}
        {% endif %}
    {% endfor %}
{% endif %}

<tr>
    {# Checkbox — shown in main list only, hidden on mobile #}
    {% if showCheckbox %}
        <td class="pe-0 d-none d-md-table-cell">
            <input class="form-check-input entry-checkbox" type="checkbox"
                   name="ids[]" value="{{ entry.id }}"
                   aria-label="{{ entry.work.deleted ? 'reading.entry.work_deleted'|trans : entry.work.title }}">
        </td>
    {% endif %}

    {# Cover art thumbnail — hidden on mobile #}
    <td class="cover-col d-none d-md-table-cell" aria-hidden="true">
        {% if not entry.work.deleted %}
            <div class="cover cover-thumbnail {{ cover_font_class(entry.work.type.value) }}"
                 style="{{ cover_gradient(entry.work.id) }}">
                <span class="cover-title">{{ entry.work.title }}</span>
            </div>
        {% endif %}
    </td>

    {# Title + author stacked — hidden on mobile #}
    <td data-label="{{ 'reading.entry.col_title'|trans }}" class="d-none d-md-table-cell">
        <div class="entry-title-cell">
            {% if entry.work.deleted %}
                <span class="entry-deleted-work entry-title">
                    {{ 'reading.entry.work_deleted'|trans }}
                </span>
            {% else %}
                <div class="entry-title">
                    <a href="{{ path('app_reading_entry_show', {id: entry.id}) }}"
                       class="text-decoration-none" style="color: inherit;">
                        {{ entry.work.title }}
                    </a>
                    {% if entry.pinned %}
                        <i class="bi bi-pin-angle-fill ms-1" style="color: #e05c7a; font-size: 0.7em;"
                           aria-label="{{ 'entry.list.pinned_entry'|trans }}"></i>
                    {% endif %}
                    {% if entry.comments %}
                        <button type="button"
                                class="btn-ghost entry-comment-trigger"
                                data-bs-toggle="offcanvas"
                                data-bs-target="#commentOffcanvas"
                                data-comment-title="{{ entry.work.title|e('html_attr') }}"
                                data-comment-body="{{ entry.comments|e('html_attr') }}"
                                aria-label="{{ 'entry.list.view_comment'|trans }}">
                            <i class="bi bi-chat-left-text" aria-hidden="true"></i>
                        </button>
                    {% endif %}
                </div>
                <div class="entry-author">
                    {{ entry.work.authors|map(a => a.name)|join(', ')|default('—') }}
                </div>
            {% endif %}
        </div>
    </td>

    {# Fandom — first fandom only, hidden on small screens #}
    <td data-label="{{ 'entry.list.col_fandom'|trans }}"
        class="d-none d-lg-table-cell">
        {% if fandomName %}
            <span class="entry-author">{{ fandomName }}</span>
        {% else %}
            <span class="text-muted">—</span>
        {% endif %}
        {% if entry.mainPairing %}
            <div class="entry-author mt-1" style="font-size: 0.85em;">
                {% if '&' in entry.mainPairing.name and '/' not in entry.mainPairing.name %}
                    <i class="bi bi-people-fill" aria-hidden="true" style="color: #e05c7a;"></i>
                {% else %}
                    <i class="bi bi-heart" aria-hidden="true" style="color: #e05c7a;"></i>
                {% endif %}
                {{ entry.mainPairing.name }}
            </div>
        {% endif %}
    </td>

    {# Word count — hidden on mobile #}
    <td data-label="{{ 'reading.entry.col_words'|trans }}" class="words-col d-none d-md-table-cell">
        {{ entry.work.words ? entry.work.words|number_format : '—' }}
    </td>

    {# Status chip — hidden on mobile #}
    <td data-label="{{ 'reading.field.status'|trans }}" class="d-none d-md-table-cell">
        <span class="{{ chipClass }}">{{ entry.status.name }}</span>
        {% if not entry.status.countsAsRead and entry.lastReadChapter %}
            {% if entry.work.chapters %}
                {% set pct = (entry.lastReadChapter / entry.work.chapters * 100)|round %}
                {% if pct > 100 %}{% set pct = 100 %}{% endif %}
                <div class="text-muted mt-1" style="font-size: 0.72rem; white-space: nowrap;">
                    ch. {{ entry.lastReadChapter }} / {{ entry.work.chapters }}
                </div>
                <div class="progress mt-1" style="height: 3px; width: 80px;">
                    <div class="progress-bar" role="progressbar"
                         style="width: {{ pct }}%"
                         aria-valuenow="{{ pct }}" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            {% else %}
                <div class="text-muted mt-1" style="font-size: 0.72rem;">
                    ch. {{ entry.lastReadChapter }}
                </div>
            {% endif %}
        {% endif %}
    </td>

    {# Date finished — hidden on small screens #}
    <td data-label="{{ 'reading.entry.col_date_finished'|trans }}"
        class="d-none d-lg-table-cell">
        {% if entry.dateFinished %}
            {{ entry.dateFinished|date }}
        {% else %}
            <span class="text-muted">—</span>
        {% endif %}
    </td>

    {# Review stars — hidden on mobile #}
    <td data-label="{{ 'reading.entry.col_review_spice'|trans }}" class="d-none d-md-table-cell">
        {% if entry.reviewStars %}
            <span class="stars-display" aria-label="{{ entry.reviewStars }} {{ 'entry.list.stars'|trans }}">
                {%- for i in 1..5 -%}
                    {{- (i <= entry.reviewStars ? '<i class="bi bi-star-fill" aria-hidden="true"></i>' : '<i class="bi bi-star" aria-hidden="true"></i>')|raw -}}
                {%- endfor -%}
            </span>
        {% else %}
            <span class="text-muted">—</span>
        {% endif %}
        {% if entry.spiceStars is not null %}
            <div style="font-size: 0.85em; margin-top: 2px;">
                {% if entry.spiceStars == 0 %}<i class="bi bi-ban spice-icon" aria-hidden="true"></i>
                {% else %}{% for i in range(1, entry.spiceStars) %}<i class="bi bi-fire spice-icon" aria-hidden="true"></i>{% endfor %}{% endif %}
            </div>
        {% endif %}
    </td>

    {# Actions menu — hidden on mobile #}
    <td class="actions-col d-none d-md-table-cell">
        <div class="dropdown">
            <button class="btn btn-ghost btn-icon btn-sm"
                    type="button"
                    data-bs-toggle="dropdown"
                    data-bs-popper-config='{"strategy":"fixed"}'
                    aria-expanded="false"
                    aria-label="{{ 'entry.list.actions'|trans }}">
                <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li>
                    <a class="dropdown-item" href="{{ path('app_reading_entry_edit', {id: entry.id}) }}">
                        <i class="bi bi-pencil me-2" aria-hidden="true"></i>
                        {{ 'action.edit'|trans }}
                    </a>
                </li>
                <li>
                    {% if usePinForm %}
                        <button type="button" class="dropdown-item"
                                data-pin-url="{{ path('app_reading_entry_toggle_pin', {id: entry.id}) }}"
                                data-pin-token="{{ csrf_token('pin-entry-' ~ entry.id) }}"
                                onclick="var f=document.getElementById('pin-form');f.action=this.dataset.pinUrl;document.getElementById('pin-form-token').value=this.dataset.pinToken;f.submit();">
                            <i class="bi bi-{{ entry.pinned ? 'pin-angle' : 'pin-angle-fill' }} me-2" aria-hidden="true"></i>
                            {{ (entry.pinned ? 'action.unpin' : 'action.pin')|trans }}
                        </button>
                    {% else %}
                        <form method="post" action="{{ path('app_reading_entry_toggle_pin', {id: entry.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('pin-entry-' ~ entry.id) }}">
                            <button type="submit" class="dropdown-item">
                                <i class="bi bi-{{ entry.pinned ? 'pin-angle' : 'pin-angle-fill' }} me-2" aria-hidden="true"></i>
                                {{ (entry.pinned ? 'action.unpin' : 'action.pin')|trans }}
                            </button>
                        </form>
                    {% endif %}
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <button type="button" class="dropdown-item text-danger"
                            data-bs-toggle="modal" data-bs-target="#deleteModal"
                            data-entry-id="{{ entry.id }}"
                            data-delete-url="{{ path('app_reading_entry_delete', {id: entry.id}) }}"
                            data-csrf-token="{{ csrf_token('delete-entry-' ~ entry.id) }}">
                        <i class="bi bi-trash me-2" aria-hidden="true"></i>
                        {{ 'action.delete'|trans }}
                    </button>
                </li>
            </ul>
        </div>
    </td>

    {# ── Mobile card — only visible below md ────────────────────── #}
    {# The td is the tap target so both collapsed and expanded zones collapse on tap.
       Interactive elements inside the expanded section stop propagation. #}
    <td colspan="{{ showCheckbox ? 9 : 8 }}" class="d-md-none entry-mobile-card"
        role="button"
        tabindex="0"
        data-bs-toggle="collapse"
        data-bs-target="#mc-{{ entry.id }}"
        aria-expanded="false"
        aria-controls="mc-{{ entry.id }}">

        {# Collapsed card #}
        <div class="mobile-entry-card">

            {# Zone 1: thumbnail + title / author / words side by side #}
            <div class="me-zone1">
                {% if not entry.work.deleted %}
                    <div class="me-cover" aria-hidden="true">
                        <div class="cover cover-thumbnail {{ cover_font_class(entry.work.type.value) }}"
                             style="{{ cover_gradient(entry.work.id) }}">
                            <span class="cover-title">{{ entry.work.title }}</span>
                        </div>
                    </div>
                {% endif %}
                <div class="me-info">
                    <div class="me-title">
                        {% if entry.work.deleted %}
                            <span class="entry-deleted-work">{{ 'reading.entry.work_deleted'|trans }}</span>
                        {% else %}
                            {{ entry.work.title }}
                            {% if entry.pinned %}
                                <i class="bi bi-pin-angle-fill ms-1" style="color: #e05c7a; font-size: 0.7em;"
                                   aria-label="{{ 'entry.list.pinned_entry'|trans }}"></i>
                            {% endif %}
                            {% if entry.comments %}
                                <i class="bi bi-chat-left-text me-comment-indicator ms-1"
                                   aria-label="{{ 'entry.list.view_comment'|trans }}"></i>
                            {% endif %}
                        {% endif %}
                    </div>
                    {% if not entry.work.deleted %}
                        <div class="me-author">
                            {{ entry.work.authors|map(a => a.name)|join(', ')|default('—') }}
                        </div>
                        {% if entry.work.words %}
                            <div class="me-meta">{{ entry.work.words|number_format }} words</div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>

            {# Zone 2: status + optional progress + stars/spice #}
            <div class="me-zone2">
                <div class="me-status-row">
                    <span class="{{ chipClass }}">{{ entry.status.name }}</span>
                    {% if not entry.status.countsAsRead and entry.lastReadChapter %}
                        <div class="me-progress">
                            <span class="me-progress-text">
                                ch. {{ entry.lastReadChapter }}{% if entry.work.chapters %} / {{ entry.work.chapters }}{% endif %}
                            </span>
                            {% if entry.work.chapters %}
                                {% set pct = (entry.lastReadChapter / entry.work.chapters * 100)|round %}
                                {% if pct > 100 %}{% set pct = 100 %}{% endif %}
                                <div class="progress" style="height: 3px; width: 60px; flex-shrink: 0;">
                                    <div class="progress-bar" role="progressbar"
                                         style="width: {{ pct }}%"
                                         aria-valuenow="{{ pct }}" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
                {% if entry.reviewStars or entry.spiceStars is not null %}
                    <div class="me-review mt-1">
                        {% if entry.reviewStars %}
                            <span class="stars-display" aria-label="{{ entry.reviewStars }} {{ 'entry.list.stars'|trans }}">
                                {%- for i in 1..5 -%}
                                    {{- (i <= entry.reviewStars ? '<i class="bi bi-star-fill" aria-hidden="true"></i>' : '<i class="bi bi-star" aria-hidden="true"></i>')|raw -}}
                                {%- endfor -%}
                            </span>
                        {% endif %}
                        {% if entry.spiceStars is not null %}
                            <span>
                                {% if entry.spiceStars == 0 %}<i class="bi bi-ban spice-icon" aria-hidden="true"></i>
                                {% else %}{% for i in range(1, entry.spiceStars) %}<i class="bi bi-fire spice-icon" aria-hidden="true"></i>{% endfor %}{% endif %}
                            </span>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        {# Expanded section — revealed on tap #}
        <div class="collapse mobile-entry-expanded" id="mc-{{ entry.id }}">

            {# Action buttons — always at top for immediate access.
               stopPropagation prevents the td toggle from firing when tapping a button. #}
            <div class="me-actions">
                {% if not entry.work.deleted %}
                    <a href="{{ path('app_work_show', {id: entry.work.id}) }}"
                       class="me-action-btn" aria-label="{{ 'reading.entry.view_work'|trans }}"
                       onclick="event.stopPropagation()">
                        <i class="bi bi-book" aria-hidden="true"></i>
                    </a>
                {% endif %}
                <a href="{{ path('app_reading_entry_edit', {id: entry.id}) }}"
                   class="me-action-btn" aria-label="{{ 'action.edit'|trans }}"
                   onclick="event.stopPropagation()">
                    <i class="bi bi-pencil" aria-hidden="true"></i>
                </a>
                {% if usePinForm %}
                    <button type="button"
                            class="me-action-btn{{ entry.pinned ? ' me-action-btn--pinned' : '' }}"
                            aria-label="{{ (entry.pinned ? 'action.unpin' : 'action.pin')|trans }}"
                            data-pin-url="{{ path('app_reading_entry_toggle_pin', {id: entry.id}) }}"
                            data-pin-token="{{ csrf_token('pin-entry-' ~ entry.id) }}"
                            onclick="event.stopPropagation();var f=document.getElementById('pin-form');f.action=this.dataset.pinUrl;document.getElementById('pin-form-token').value=this.dataset.pinToken;f.submit();">
                        <i class="bi bi-{{ entry.pinned ? 'pin-angle-fill' : 'pin-angle' }}" aria-hidden="true"></i>
                    </button>
                {% else %}
                    <form method="post" action="{{ path('app_reading_entry_toggle_pin', {id: entry.id}) }}"
                          onclick="event.stopPropagation()">
                        <input type="hidden" name="_token" value="{{ csrf_token('pin-entry-' ~ entry.id) }}">
                        <button type="submit"
                                class="me-action-btn{{ entry.pinned ? ' me-action-btn--pinned' : '' }}"
                                aria-label="{{ (entry.pinned ? 'action.unpin' : 'action.pin')|trans }}"
                                onclick="event.stopPropagation()">
                            <i class="bi bi-{{ entry.pinned ? 'pin-angle-fill' : 'pin-angle' }}" aria-hidden="true"></i>
                        </button>
                    </form>
                {% endif %}
                <button type="button"
                        class="me-action-btn me-action-btn--danger"
                        data-bs-toggle="modal" data-bs-target="#deleteModal"
                        data-entry-id="{{ entry.id }}"
                        data-delete-url="{{ path('app_reading_entry_delete', {id: entry.id}) }}"
                        data-csrf-token="{{ csrf_token('delete-entry-' ~ entry.id) }}"
                        aria-label="{{ 'action.delete'|trans }}"
                        onclick="event.stopPropagation()">
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </button>
            </div>

            {# Additional metadata #}
            {% if fandomName or entry.mainPairing or entry.dateFinished %}
                <div class="me-fields">
                    {% if fandomName %}
                        <div class="me-field">
                            <span class="me-field-value">{{ fandomName }}</span>
                        </div>
                    {% endif %}
                    {% if entry.mainPairing %}
                        <div class="me-field">
                            {% if '&' in entry.mainPairing.name and '/' not in entry.mainPairing.name %}
                                <i class="bi bi-people-fill" aria-hidden="true" style="color: #e05c7a;"></i>
                            {% else %}
                                <i class="bi bi-heart" aria-hidden="true" style="color: #e05c7a;"></i>
                            {% endif %}
                            <span class="me-field-value">{{ entry.mainPairing.name }}</span>
                        </div>
                    {% endif %}
                    {% if entry.dateFinished %}
                        <div class="me-field">
                            <i class="bi bi-calendar3" aria-hidden="true"></i>
                            <span class="me-field-value">{{ entry.dateFinished|date }}</span>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            {# Comment — always last #}
            {% if entry.comments %}
                <div class="me-comment">{{ entry.comments }}</div>
            {% endif %}
        </div>

    </td>
</tr>
