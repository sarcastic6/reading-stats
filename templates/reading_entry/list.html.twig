{% extends 'base.html.twig' %}

{% block title %}{{ 'entry.list.heading'|trans }}{% endblock %}

{% block body %}

{# ── Page header ──────────────────────────────────────────────────────────── #}
<div class="page-header">
    <div class="page-header-text">
        <h1 class="page-title">{{ 'entry.list.heading'|trans }}</h1>
        <p class="page-subtitle text-muted mb-0">
            {% if has_filters %}
                {{ 'entry.list.entry_count_filtered'|trans({'%count%': total, '%total%': stat_total_words|number_format}) }}
            {% else %}
                {% if total == 1 %}
                    {{ 'entry.list.entry_count_one'|trans({'%count%': total}) }}
                {% else %}
                    {{ 'entry.list.entry_count'|trans({'%count%': total}) }}
                {% endif %}
            {% endif %}
        </p>
    </div>
    <div class="page-header-actions">
        {# Filter toggle — offcanvas trigger #}
        <button class="btn btn-secondary btn-sm" type="button"
                data-bs-toggle="offcanvas"
                data-bs-target="#filterOffcanvas"
                aria-controls="filterOffcanvas">
            <i class="bi bi-funnel" aria-hidden="true"></i>
            {{ 'entry.filter.show_filters'|trans }}
            {% if has_filters %}
                <span class="filter-badge ms-1">{{ active_filter_count }}</span>
            {% endif %}
        </button>
        <a href="{{ path('app_work_select') }}" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            {{ 'entry.list.add'|trans }}
        </a>
    </div>
</div>

{# ── Summary stat strip ───────────────────────────────────────────────────── #}
<div class="stat-strip">
    <div class="stat-strip-item">
        <span class="stat-strip-value">{{ stat_total_words|number_format }}</span>
        <span class="stat-strip-label">{{ 'entry.list.stat_total_words'|trans }}</span>
    </div>
    <div class="stat-strip-item">
        <span class="stat-strip-value">{{ stat_finish_rate }}%</span>
        <span class="stat-strip-label">{{ 'entry.list.stat_finish_rate'|trans }}</span>
    </div>
    <div class="stat-strip-item">
        {% if stat_avg_review %}
            <span class="stat-strip-value"><i class="bi bi-star-fill star-icon" aria-hidden="true"></i> {{ stat_avg_review }}</span>
        {% else %}
            <span class="stat-strip-value stat-strip-value--empty">—</span>
        {% endif %}
        <span class="stat-strip-label">{{ 'entry.list.stat_avg_review'|trans }}</span>
    </div>
    <div class="stat-strip-item">
        {% if has_filters %}
            <span class="stat-strip-value">{{ stat_completed }}</span>
            <span class="stat-strip-label">{{ 'entry.list.stat_completed'|trans }}</span>
        {% else %}
            <span class="stat-strip-value">{{ stat_this_year }}</span>
            <span class="stat-strip-label">{{ 'entry.list.stat_this_year'|trans({'%year%': stat_current_year}) }}</span>
        {% endif %}
    </div>
</div>

{# ── Pinned entries section — hidden when nothing is pinned ───────────────── #}
{% if pinned_entries is not empty %}
<section class="pinned-section mb-4" aria-label="{{ 'reading.entry.pinned_heading'|trans }}">
    <h2 class="pinned-section-heading">
        <i class="bi bi-pin-angle-fill me-2" aria-hidden="true"></i>
        {{ 'reading.entry.pinned_heading'|trans }}
    </h2>
    <div class="table-wrapper" style="overflow: visible;">
        <table class="data-table table-responsive-card">
            <thead>
                <tr>
                    <th class="cover-col d-none d-md-table-cell" aria-hidden="true"></th>
                    <th class="d-none d-md-table-cell">{{ 'reading.entry.col_title'|trans }}</th>
                    <th class="d-none d-lg-table-cell">{{ 'entry.list.col_fandom'|trans }}</th>
                    <th class="words-col d-none d-md-table-cell">{{ 'reading.entry.col_words'|trans }}</th>
                    <th class="d-none d-md-table-cell">{{ 'reading.field.status'|trans }}</th>
                    <th class="d-none d-lg-table-cell">{{ 'reading.entry.col_date_finished'|trans }}</th>
                    <th class="d-none d-md-table-cell">{{ 'reading.entry.col_review_spice'|trans }}</th>
                    <th class="actions-col d-none d-md-table-cell"></th>
                </tr>
            </thead>
            <tbody>
                {% for entry in pinned_entries %}
                    {% include 'reading_entry/_entry_row.html.twig' with {entry: entry, showCheckbox: false} only %}
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endif %}

{# ── Active filter chips — always visible when filters are set ────────────── #}
{% include 'reading_entry/_filter_chips.html.twig' with {
    has_filters: has_filters,
    filters: filters,
    statuses: statuses,
    seriesName: seriesName ?? null
} only %}

{# ── Empty state ──────────────────────────────────────────────────────────── #}
{% if entries is empty %}
    <div class="table-empty-state">
        {% if has_filters %}
            <div class="table-empty-icon">
                <i class="bi bi-funnel" aria-hidden="true"></i>
            </div>
            <p class="table-empty-title">{{ 'entry.empty.no_results_heading'|trans }}</p>
            <p class="table-empty-text">{{ 'entry.empty.no_results_text'|trans }}</p>
            <a href="{{ path('app_reading_entry_list') }}" class="btn btn-secondary btn-sm mt-3">
                {{ 'entry.filter.clear_all'|trans }}
            </a>
        {% else %}
            <div class="table-empty-icon">
                <i class="bi bi-book" aria-hidden="true"></i>
            </div>
            <p class="table-empty-title">{{ 'entry.empty.heading'|trans }}</p>
            <p class="table-empty-text">{{ 'entry.empty.text'|trans }}</p>
            <a href="{{ path('app_work_select') }}" class="btn btn-primary btn-sm mt-3">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                {{ 'entry.list.add'|trans }}
            </a>
        {% endif %}
    </div>
{% else %}

{# ── Bulk actions form — wraps the table so checkboxes are inside the form ── #}
<form id="bulk-form" method="post" action="">
    <input type="hidden" name="_token" id="bulk-token" value="{{ csrf_token('bulk-action') }}">
    <input type="hidden" name="_query" value="{{ app.request.queryString }}">

    {# Bulk action bar — shown by JS when entries are checked #}
    <div id="bulk-action-bar" class="d-none bulk-action-bar" aria-live="polite">
        <span id="bulk-count" class="bulk-selected-count"></span>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <select id="bulk-status-select" name="status_id" class="form-select form-select-sm" style="width: auto;">
                <option value="">{{ 'reading.bulk.change_status'|trans }}</option>
                {% for status in statuses %}
                    <option value="{{ status.id }}">{{ status.name }}</option>
                {% endfor %}
            </select>
            <button type="button" id="bulk-status-btn" class="btn btn-secondary btn-sm"
                    data-action-url="{{ path('app_reading_entry_bulk_status') }}">
                {{ 'reading.bulk.apply_status'|trans }}
            </button>
        </div>
        <button type="button" id="bulk-delete-btn" class="btn btn-outline-danger btn-sm ms-auto"
                data-bs-toggle="modal" data-bs-target="#bulkDeleteModal"
                data-action-url="{{ path('app_reading_entry_bulk_delete') }}">
            <i class="bi bi-trash" aria-hidden="true"></i>
            {{ 'reading.bulk.delete_selected'|trans }}
        </button>
    </div>

    {# ── Entry table ─────────────────────────────────────────────────────── #}
    <div class="table-wrapper">
        <table class="data-table table-responsive-card">
            <thead>
                <tr>
                    <th scope="col" style="width: 1%; padding-right: 0;">
                        <input class="form-check-input" type="checkbox" id="select-all"
                               aria-label="{{ 'reading.bulk.select_all'|trans }}">
                    </th>
                    <th scope="col" class="cover-col" aria-hidden="true"></th>
                    {# Title + Author compound sort header #}
                    <th scope="col"{% if current_sort in ['title', 'author'] %} class="th-sort-active"{% endif %}>
                        {% set isActive = current_sort == 'title' %}
                        {% set nextDir = isActive and current_dir == 'asc' ? 'desc' : 'asc' %}
                        <a href="{{ path('app_reading_entry_list', filters|merge({'sort': 'title', 'dir': nextDir, 'page': 1})) }}"
                           class="text-decoration-none d-flex align-items-center gap-1 {{ isActive ? 'fw-semibold text-body' : 'text-muted' }}">
                            {{ 'reading.entry.col_title'|trans }}
                            <i class="bi bi-{{ isActive ? 'caret-' ~ (current_dir == 'asc' ? 'up' : 'down') ~ '-fill' : 'chevron-expand opacity-25' }}"
                               style="font-size: 0.6em;" aria-hidden="true"></i>
                        </a>
                        {% set isActive = current_sort == 'author' %}
                        {% set nextDir = isActive and current_dir == 'asc' ? 'desc' : 'asc' %}
                        <a href="{{ path('app_reading_entry_list', filters|merge({'sort': 'author', 'dir': nextDir, 'page': 1})) }}"
                           class="text-decoration-none d-flex align-items-center gap-1 {{ isActive ? 'fw-semibold text-body' : 'text-muted' }}"
                           style="font-size: 0.8em; font-weight: normal;">
                            {{ 'reading.filter.author'|trans }}
                            <i class="bi bi-{{ isActive ? 'caret-' ~ (current_dir == 'asc' ? 'up' : 'down') ~ '-fill' : 'chevron-expand opacity-25' }}"
                               style="font-size: 0.6em;" aria-hidden="true"></i>
                        </a>
                    </th>

                    {# Fandom + Main Pairing header — not sortable #}
                    <th scope="col" class="d-none d-lg-table-cell">
                        <span class="text-muted">{{ 'entry.list.col_fandom'|trans }}</span>
                        <div class="text-muted" style="font-size: 0.8em; font-weight: normal;">
                            <i class="bi bi-heart" aria-hidden="true" style="color: #e05c7a;"></i>
                            <i class="bi bi-people-fill" aria-hidden="true" style="color: #e05c7a;"></i>
                            {{ 'reading.field.main_pairing'|trans }}
                        </div>
                    </th>

                    <th scope="col">{{ 'reading.entry.col_words'|trans }}</th>

                    {# Status sort header #}
                    {% set isActive = current_sort == 'status' %}
                    {% set nextDir = isActive and current_dir == 'asc' ? 'desc' : 'asc' %}
                    <th scope="col"{% if isActive %} class="th-sort-active"{% endif %}>
                        <a href="{{ path('app_reading_entry_list', filters|merge({'sort': 'status', 'dir': nextDir, 'page': 1})) }}"
                           class="text-decoration-none d-flex align-items-center gap-1 {{ isActive ? 'fw-semibold text-body' : 'text-muted' }}">
                            {{ 'reading.field.status'|trans }}
                            <i class="bi bi-{{ isActive ? 'caret-' ~ (current_dir == 'asc' ? 'up' : 'down') ~ '-fill' : 'chevron-expand opacity-25' }}"
                               style="font-size: 0.6em;" aria-hidden="true"></i>
                        </a>
                    </th>

                    {# Date Finished sort header — hidden on small screens #}
                    {% set isActive = current_sort == 'dateFinished' %}
                    {% set nextDir = isActive and current_dir == 'desc' ? 'asc' : 'desc' %}
                    <th scope="col" class="d-none d-lg-table-cell{% if isActive %} th-sort-active{% endif %}">
                        <a href="{{ path('app_reading_entry_list', filters|merge({'sort': 'dateFinished', 'dir': nextDir, 'page': 1})) }}"
                           class="text-decoration-none d-flex align-items-center gap-1 {{ isActive ? 'fw-semibold text-body' : 'text-muted' }}">
                            {{ 'reading.entry.col_date_finished'|trans }}
                            <i class="bi bi-{{ isActive ? 'caret-' ~ (current_dir == 'asc' ? 'up' : 'down') ~ '-fill' : 'chevron-expand opacity-25' }}"
                               style="font-size: 0.6em;" aria-hidden="true"></i>
                        </a>
                    </th>
                    <th scope="col">{{ 'reading.entry.col_review_spice'|trans }}</th>
                    <th scope="col" class="actions-col"></th>
                </tr>
            </thead>
            <tbody>
                {% for entry in entries %}
                    {% include 'reading_entry/_entry_row.html.twig' with {entry: entry, showCheckbox: true, usePinForm: true} only %}
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination #}
    {% if total_pages > 1 %}
        <nav aria-label="{{ 'entry.list.pagination'|trans }}" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item {% if page <= 1 %}disabled{% endif %}">
                    <a class="page-link" href="{{ path('app_reading_entry_list', filters|merge({page: page - 1})) }}"
                       aria-label="{{ 'pagination.previous'|trans }}">
                        &laquo; {{ 'pagination.previous'|trans }}
                    </a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">{{ page }} / {{ total_pages }}</span>
                </li>
                <li class="page-item {% if page >= total_pages %}disabled{% endif %}">
                    <a class="page-link" href="{{ path('app_reading_entry_list', filters|merge({page: page + 1})) }}"
                       aria-label="{{ 'pagination.next'|trans }}">
                        {{ 'pagination.next'|trans }} &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    {% endif %}
</form>

{% endif %}{# end entries is not empty #}

{# ── Shared overlays: pin form + delete modals ────────────────────────────── #}
{% include 'reading_entry/_modals.html.twig' %}

{# ── Comment offcanvas — populated by JS from data attributes ─────────────── #}
<div class="offcanvas offcanvas-end comment-offcanvas"
     tabindex="-1"
     id="commentOffcanvas"
     aria-labelledby="commentOffcanvasTitle">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title text-truncate" id="commentOffcanvasTitle"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="{{ 'action.close'|trans }}"></button>
    </div>
    <div class="offcanvas-body">
        <p id="commentOffcanvasBody" class="comment-offcanvas-text mb-0"></p>
    </div>
</div>

{# ── Filter offcanvas ─────────────────────────────────────────────────────── #}
{% include 'reading_entry/_filter_offcanvas.html.twig' with {
    filters: filters,
    statuses: statuses,
    languages: languages,
    metadataTypes: metadataTypes,
    metadataDropdownValues: metadataDropdownValues
} only %}

<script type="module" src="{{ asset('js/bulk-actions.js') }}"></script>

<script>
// Wire comment offcanvas: populate title and body from the triggering button's data attributes
document.addEventListener('DOMContentLoaded', function () {
    var offcanvas = document.getElementById('commentOffcanvas');
    if (!offcanvas) { return; }
    offcanvas.addEventListener('show.bs.offcanvas', function (event) {
        var button = event.relatedTarget;
        if (!button) { return; }
        document.getElementById('commentOffcanvasTitle').textContent = button.getAttribute('data-comment-title') || '';
        document.getElementById('commentOffcanvasBody').textContent = button.getAttribute('data-comment-body') || '';
    });
});

// Wire single-entry delete modal: set action URL and CSRF token from the triggering button's data attributes
document.addEventListener('DOMContentLoaded', function () {
    var deleteModal = document.getElementById('deleteModal');
    if (!deleteModal) { return; }
    deleteModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        if (!button) { return; }
        var form = document.getElementById('singleDeleteForm');
        var tokenInput = document.getElementById('singleDeleteToken');
        if (form) { form.action = button.getAttribute('data-delete-url') || ''; }
        if (tokenInput) { tokenInput.value = button.getAttribute('data-csrf-token') || ''; }
    });
});
</script>
{% endblock %}
